{
  "multipart": [
    { "when": { "facing": "north", "lit": "false" }, "apply": { "model": "dynamic_streetlight:block/streetlight_light_head_1_off" } },
    { "when": { "facing": "east", "lit": "false" },  "apply": { "model": "dynamic_streetlight:block/streetlight_light_head_1_off", "y": 90 } },
    { "when": { "facing": "south", "lit": "false" }, "apply": { "model": "dynamic_streetlight:block/streetlight_light_head_1_off", "y": 180 } },
    { "when": { "facing": "west", "lit": "false" },  "apply": { "model": "dynamic_streetlight:block/streetlight_light_head_1_off", "y": 270 } },

    { "when": { "facing": "north", "lit": "true" },  "apply": { "model": "dynamic_streetlight:block/streetlight_light_head_1" } },
    { "when": { "facing": "east", "lit": "true" },   "apply": { "model": "dynamic_streetlight:block/streetlight_light_head_1", "y": 90 } },
    { "when": { "facing": "south", "lit": "true" },  "apply": { "model": "dynamic_streetlight:block/streetlight_light_head_1", "y": 180 } },
    { "when": { "facing": "west", "lit": "true" },   "apply": { "model": "dynamic_streetlight:block/streetlight_light_head_1", "y": 270 } }
  ]
}


